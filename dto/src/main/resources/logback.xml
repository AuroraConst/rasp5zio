<configuration DEBUG="true" scan="true">

    <root level="DEBUG">
        <appender-ref ref="STDOUT"/>
    </root>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern> %highlight(%-5level) [%thread] %cyan(%logger{36}) %msg%n</pattern>
        </encoder>
    </appender>

</configuration>
